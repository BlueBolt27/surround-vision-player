<Window x:Class="SurroundVisionPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Surround Vision Player v0.3.3 — 2027 Chevy Bolt"
        Width="1280" Height="820" MinWidth="900" MinHeight="580"
        Background="#070B14" Foreground="#C8E0F0"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

    <Window.Resources>

        <!-- ── Brushes ── -->
        <SolidColorBrush x:Key="BgBrush"      Color="#070B14"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#0C1222"/>
        <SolidColorBrush x:Key="BorderBrush"  Color="#163050"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#00C8FF"/>
        <SolidColorBrush x:Key="TextBrush"    Color="#C8E0F0"/>
        <SolidColorBrush x:Key="SubBrush"     Color="#3A5070"/>

        <!-- ── Menu: expander toggle ── -->
        <Style x:Key="MenuItemExpanderStyle" TargetType="ToggleButton">
            <Setter Property="Focusable"  Value="False"/>
            <Setter Property="Width"      Value="16"/>
            <Setter Property="Height"     Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── MenuItem with dark popup ── -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground"  Value="#C8E0F0"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="10,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock x:Name="GestureText"
                                               Grid.Column="1"
                                               Text="{TemplateBinding InputGestureText}"
                                               Foreground="#3A5070"
                                               VerticalAlignment="Center"
                                               Margin="24,0,0,0"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   HorizontalOffset="-1"
                                   PopupAnimation="Fade">
                                <Border Background="#0C1222"
                                        BorderBrush="#163050"
                                        BorderThickness="1"
                                        Padding="0,3">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00C8FF" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.25"/>
                                    </Border.Effect>
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="Bd"          Property="Padding"    Value="8,6"/>
                                <Setter TargetName="GestureText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Bd"         Property="Padding"    Value="8,6"/>
                                <Setter TargetName="PART_Popup" Property="Placement"  Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D2035"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D2035"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#3A5070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Separator ── -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#163050"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}"
                                Height="{TemplateBinding Height}"
                                Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Regular button ── -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"       Value="#0C1222"/>
            <Setter Property="Foreground"       Value="#C8E0F0"/>
            <Setter Property="BorderBrush"      Value="#1E3A5F"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,5"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#0D2035"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C8FF"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00C8FF" BlurRadius="8"
                                                          ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#003050"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C8FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#243040"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#162030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Angle toggle button — parallelogram ── -->
        <Style x:Key="AngleBtn" TargetType="ToggleButton">
            <Setter Property="Background"       Value="#0C1222"/>
            <Setter Property="Foreground"       Value="#506070"/>
            <Setter Property="BorderBrush"      Value="#1E3A5F"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="0,8"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <!-- Transparent outer border for full-rect hit testing -->
                        <Border Background="Transparent">
                            <Border x:Name="Bd"
                                    Margin="5,0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <SkewTransform AngleX="-10"/>
                                </Border.RenderTransform>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform>
                                        <SkewTransform AngleX="10"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#001828"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C8FF"/>
                                <Setter Property="Foreground" Value="#00C8FF"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00C8FF" BlurRadius="14"
                                                          ShadowDepth="0" Opacity="0.85"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#0D2035"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#005880"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.25"/>
                                <Setter Property="Cursor"  Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TabControl ── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"  Value="#0C1222"/>
            <Setter Property="BorderBrush" Value="#163050"/>
            <Setter Property="Padding"     Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <TabPanel DockPanel.Dock="Top"
                                      IsItemsHost="True"
                                      Background="Transparent"/>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,4,0,0">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TabItem ── -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground"       Value="#3A5070"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Padding"          Value="10,5"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#00C8FF"/>
                                <Setter Property="Foreground" Value="#00C8FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C8E0F0"/>
                                <Setter TargetName="Bd" Property="Background" Value="#0D2035"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeView expander button ── -->
        <Style x:Key="TreeExpanderBtn" TargetType="ToggleButton">
            <Setter Property="Focusable"        Value="False"/>
            <Setter Property="Width"            Value="16"/>
            <Setter Property="Height"           Value="16"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="16" Height="16">
                            <Path x:Name="Arrow"
                                  Data="M2,4 L8,4 L5,8 Z"
                                  Fill="#3A5070"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Arrow" Property="Data" Value="M4,2 L8,5 L4,8 Z"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#C8E0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TreeView ── -->
        <Style TargetType="TreeView">
            <Setter Property="Background"       Value="#0C1222"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="#C8E0F0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ── TreeViewItem ── -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground"       Value="#C8E0F0"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="IsExpanded"       Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Grid.Row="0"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="0" Padding="2,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  Style="{StaticResource TreeExpanderBtn}"
                                                  IsChecked="{Binding IsExpanded,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"/>
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"
                                                      Margin="2,0,0,0"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1"
                                            Margin="16,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#001A28"/>
                                <Setter Property="Foreground" Value="#00C8FF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#0D2035"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Date-group nodes: dim, non-selectable, top margin -->
        <Style x:Key="DateNodeStyle" TargetType="TreeViewItem"
               BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="Foreground" Value="#3A5070"/>
            <Setter Property="Focusable"  Value="False"/>
            <Setter Property="Margin"     Value="0,6,0,0"/>
            <Setter Property="FontSize"   Value="11"/>
        </Style>

        <!-- ── ProgressBar ── -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background"  Value="#0D2035"/>
            <Setter Property="Foreground"  Value="#00C8FF"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Height"      Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00C8FF" BlurRadius="6"
                                                      ShadowDepth="0" Opacity="0.8"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Seek Slider ── -->
        <Style x:Key="SeekSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#00C8FF">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#00C8FF" BlurRadius="5"
                                                                          ShadowDepth="0" Opacity="0.7"/>
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Path Data="M 0,-8 L 7,0 L 0,8 L -7,0 Z"
                                                      Fill="#00C8FF"
                                                      Stroke="#001828" StrokeThickness="1">
                                                    <Path.Effect>
                                                        <DropShadowEffect Color="#00C8FF" BlurRadius="8"
                                                                          ShadowDepth="0" Opacity="0.9"/>
                                                    </Path.Effect>
                                                </Path>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#163050"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="O" Command="{x:Static ApplicationCommands.Open}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ── Menu bar ── -->
        <Menu x:Name="MainMenu" DockPanel.Dock="Top" Background="#0C1222" Foreground="#C8E0F0">
            <MenuItem Header="_File">
                <MenuItem Header="Set Archive Folder…" Click="SetArchiveFolder_Click"/>
                <MenuItem x:Name="MenuAutoArchive" Click="MenuAutoArchive_Click"/>
                <Separator/>
                <MenuItem Header="Open Thumb Drive…"   Click="OpenDrive_Click"
                          InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="Quit"                Click="Quit_Click"
                          InputGestureText="Ctrl+Q"/>
            </MenuItem>
        </Menu>

        <Grid x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════ LEFT SIDEBAR ═══════════════ -->
            <DockPanel x:Name="Sidebar" Grid.Column="0" Margin="8,8,4,8">

                <TextBlock x:Name="CountLabel" DockPanel.Dock="Bottom"
                           Foreground="#3A5070" FontSize="11"
                           TextAlignment="Center" Margin="0,4,0,0"/>

                <TabControl x:Name="SourceTabs"
                            SelectionChanged="SourceTabs_SelectionChanged">

                    <!-- Thumb Drive tab -->
                    <TabItem Header="Thumb Drive">
                        <DockPanel>
                            <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnArchive" Grid.Column="0"
                                        Content="⬇  Archive"
                                        Style="{StaticResource DarkBtn}"
                                        IsEnabled="False"
                                        Click="Archive_Click"
                                        ToolTip="Copy selected trip to the archive folder"/>
                                <Button x:Name="BtnDelete" Grid.Column="2"
                                        Content="✕  Delete"
                                        Style="{StaticResource DarkBtn}"
                                        IsEnabled="False"
                                        Click="DeleteDrive_Click"
                                        ToolTip="Permanently delete selected trip from the thumb drive"/>
                            </Grid>
                            <TreeView x:Name="DriveTree"
                                      SelectedItemChanged="DriveTree_SelectedItemChanged"/>
                        </DockPanel>
                    </TabItem>

                    <!-- Archive tab -->
                    <TabItem Header="Archive">
                        <DockPanel>
                            <Button x:Name="BtnDeleteArchive" DockPanel.Dock="Bottom"
                                    Content="✕  Delete Trip"
                                    Style="{StaticResource DarkBtn}"
                                    IsEnabled="False"
                                    Click="DeleteArchive_Click"
                                    Margin="0,4,0,0"
                                    ToolTip="Permanently delete selected trip from the archive"/>
                            <TreeView x:Name="ArchiveTree"
                                      SelectedItemChanged="ArchiveTree_SelectedItemChanged"/>
                        </DockPanel>
                    </TabItem>

                    <!-- Clips tab -->
                    <TabItem Header="Clips">
                        <DockPanel>
                            <Button x:Name="BtnDeleteClip" DockPanel.Dock="Bottom"
                                    Content="✕  Delete Clip"
                                    Style="{StaticResource DarkBtn}"
                                    IsEnabled="False"
                                    Click="DeleteClip_Click"
                                    Margin="0,4,0,0"
                                    ToolTip="Permanently delete selected exported clip"/>
                            <TreeView x:Name="ClipsTree"
                                      SelectedItemChanged="ClipsTree_SelectedItemChanged"/>
                        </DockPanel>
                    </TabItem>

                </TabControl>

            </DockPanel>

            <!-- ═══════════════ MAIN AREA ═══════════════ -->
            <DockPanel Grid.Column="1" Margin="4,8,8,8" LastChildFill="True">

                <!-- Progress bar (visible only during archive/export) -->
                <ProgressBar x:Name="ArchiveProgress"
                             DockPanel.Dock="Bottom"
                             Visibility="Collapsed"
                             Margin="0,2,0,0"/>

                <!-- Status bar -->
                <TextBlock x:Name="StatusLabel" DockPanel.Dock="Bottom"
                           Foreground="#3A5070" FontSize="11"
                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>

                <!-- Bookmark note input (shown when B is pressed) -->
                <Border x:Name="BookmarkInputPanel" DockPanel.Dock="Bottom"
                        Visibility="Collapsed"
                        BorderBrush="#163050" BorderThickness="0,1,0,0"
                        Background="#0C1222" Padding="6,4" Margin="0,2,0,0">
                    <DockPanel>
                        <Button x:Name="BtnBookmarkSave" DockPanel.Dock="Right"
                                Content="Save" Style="{StaticResource DarkBtn}"
                                Padding="12,3" Margin="4,0,0,0"
                                Click="BtnBookmarkSave_Click"/>
                        <Button x:Name="BtnBookmarkCancel" DockPanel.Dock="Right"
                                Content="Cancel" Style="{StaticResource DarkBtn}"
                                Padding="12,3" Margin="4,0,0,0"
                                Click="BtnBookmarkCancel_Click"/>
                        <TextBox x:Name="BookmarkNoteBox"
                                 Background="#163050" Foreground="#C8E0F0"
                                 CaretBrush="#00C8FF"
                                 BorderBrush="#00C8FF" BorderThickness="1"
                                 Padding="6,3" VerticalAlignment="Center"
                                 KeyDown="BookmarkNoteBox_KeyDown"/>
                    </DockPanel>
                </Border>

                <!-- Transport + speed -->
                <Border x:Name="TransportPanel" DockPanel.Dock="Bottom"
                        BorderBrush="#163050" BorderThickness="1" CornerRadius="0"
                        Margin="0,6,0,0" Padding="8,6" Background="#0C1222">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                            <Button x:Name="BtnBookmark" Content="Bookmark"
                                    Style="{StaticResource DarkBtn}"
                                    Padding="8,5" Click="BtnBookmark_Click"
                                    ToolTip="Add bookmark at current position [B]"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="10,0,0,0">
                            <ToggleButton x:Name="BtnQuad" Content="QUAD"
                                          Style="{StaticResource AngleBtn}"
                                          Width="60" Margin="0,0,12,0"
                                          Click="BtnQuad_Click"
                                          ToolTip="Toggle quad view [Q]"/>
                            <TextBlock Text="Speed:" Foreground="#3A5070"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Button Content="½×" Style="{StaticResource DarkBtn}"
                                    Click="HalfSpeed_Click"  MinWidth="44" Margin="2,0"/>
                            <Button Content="1×"  Style="{StaticResource DarkBtn}"
                                    Click="NormalSpeed_Click" MinWidth="44" Margin="2,0"/>
                            <Button Content="2×"  Style="{StaticResource DarkBtn}"
                                    Click="DoubleSpeed_Click" MinWidth="44" Margin="2,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="⏮" Style="{StaticResource DarkBtn}"
                                    Click="Beginning_Click" FontSize="18"
                                    Width="50" Height="44" Margin="2,0"
                                    ToolTip="Go to trip start"/>
                            <Button Content="⏪" Style="{StaticResource DarkBtn}"
                                    Click="StepBack_Click" FontSize="18"
                                    Width="50" Height="44" Margin="2,0"
                                    ToolTip="Rewind 10 s  [←]"/>
                            <Button x:Name="BtnPlay" Content="▶"
                                    Style="{StaticResource DarkBtn}" FontSize="18"
                                    Click="Play_Click" Width="50" Height="44" Margin="2,0"
                                    ToolTip="Play / Pause  [Space]"/>
                            <Button Content="⏩" Style="{StaticResource DarkBtn}"
                                    Click="StepFwd_Click" FontSize="18"
                                    Width="50" Height="44" Margin="2,0"
                                    ToolTip="Fast-forward 10 s  [→]"/>
                            <Button Content="⏭" Style="{StaticResource DarkBtn}"
                                    Click="End_Click" FontSize="18"
                                    Width="50" Height="44" Margin="2,0"
                                    ToolTip="Go to end of current clip"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- In/Out marker strip -->
                <Border x:Name="InOutPanel" DockPanel.Dock="Bottom"
                        BorderBrush="#163050" BorderThickness="0,1,0,0"
                        Background="#0C1222" Padding="6,4" Margin="0,2,0,0">
                    <DockPanel>
                        <Button x:Name="BtnExportClip" DockPanel.Dock="Right"
                                Content="Export Clip"
                                Style="{StaticResource DarkBtn}"
                                IsEnabled="False"
                                Click="ExportClip_Click"
                                Margin="8,0,0,0"
                                ToolTip="Export the marked selection [Ctrl+E]"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnMarkIn" Content="Mark In [I]"  Style="{StaticResource DarkBtn}"
                                    Padding="8,3" Margin="0,0,8,0" Click="MarkIn_Click"
                                    ToolTip="Set in-point at current position [I]"/>
                            <TextBlock x:Name="InLabel"  Text="–"
                                       Foreground="#00C8FF" VerticalAlignment="Center"
                                       FontSize="12" MinWidth="38" Margin="0,0,4,0"/>
                            <TextBlock Text="→" Foreground="#2A3A50" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock x:Name="SelectionDurLabel" Text=""
                                       Foreground="#3A5070" VerticalAlignment="Center"
                                       FontSize="12" MinWidth="38" Margin="0,0,4,0"/>
                            <TextBlock Text="→" Foreground="#2A3A50" VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock x:Name="OutLabel" Text="–"
                                       Foreground="#00C8FF" VerticalAlignment="Center"
                                       FontSize="12" MinWidth="38" Margin="0,0,8,0"/>
                            <Button x:Name="BtnMarkOut" Content="Mark Out [O]" Style="{StaticResource DarkBtn}"
                                    Padding="8,3" Click="MarkOut_Click"
                                    ToolTip="Set out-point at current position [O]"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Seek bar -->
                <Grid x:Name="SeekBarGrid" DockPanel.Dock="Bottom" Margin="0,6,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TimeLabel" Grid.Column="0"
                               Text="0:00" Foreground="#C8E0F0"
                               VerticalAlignment="Center"/>
                    <Slider x:Name="SeekSlider" Grid.Column="1"
                            Style="{StaticResource SeekSliderStyle}"
                            Minimum="0" Maximum="10000" Value="0"
                            VerticalAlignment="Center"
                            PreviewMouseLeftButtonDown="SeekSlider_MouseDown"
                            PreviewMouseLeftButtonUp="SeekSlider_MouseUp"
                            ValueChanged="SeekSlider_ValueChanged"/>
                    <Canvas x:Name="BookmarkCanvas" Grid.Column="1"
                            IsHitTestVisible="True"
                            SizeChanged="BookmarkCanvas_SizeChanged"/>
                    <TextBlock x:Name="DurLabel" Grid.Column="2"
                               Text="0:00" Foreground="#C8E0F0"
                               TextAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <!-- Active angle label -->
                <TextBlock x:Name="AngleLabel" DockPanel.Dock="Bottom"
                           Text="FRONT" HorizontalAlignment="Center"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#00C8FF" Margin="0,2,0,2">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#00C8FF" BlurRadius="10"
                                          ShadowDepth="0" Opacity="0.6"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Angle selector buttons -->
                <Border x:Name="AngleBtnsPanel" DockPanel.Dock="Bottom"
                        BorderBrush="#163050" BorderThickness="1" CornerRadius="0"
                        Margin="0,4,0,0" Padding="4,6" Background="#0C1222">
                    <UniformGrid Rows="1">
                        <ToggleButton x:Name="BtnFront" Content="FRONT"
                                      Style="{StaticResource AngleBtn}"
                                      IsChecked="True"
                                      Click="Angle_Click" Tag="FRONT"/>
                        <ToggleButton x:Name="BtnLeft"  Content="LEFT"
                                      Style="{StaticResource AngleBtn}"
                                      Click="Angle_Click" Tag="LEFT"/>
                        <ToggleButton x:Name="BtnRear"  Content="REAR"
                                      Style="{StaticResource AngleBtn}"
                                      Click="Angle_Click" Tag="REAR"/>
                        <ToggleButton x:Name="BtnRight" Content="RIGHT"
                                      Style="{StaticResource AngleBtn}"
                                      Click="Angle_Click" Tag="RIGHT"/>
                    </UniformGrid>
                </Border>

                <!-- 4 stacked MediaElements -->
                <Grid x:Name="VideoGrid" Background="Black">
                    <MediaElement x:Name="VideoFront"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" Visibility="Visible"
                                  MediaOpened="Media_Opened"
                                  MediaEnded="Media_Ended"
                                  MediaFailed="Media_Failed"/>
                    <MediaElement x:Name="VideoLeft"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" Visibility="Hidden" IsMuted="True"
                                  MediaOpened="Media_Opened"
                                  MediaEnded="Media_Ended"
                                  MediaFailed="Media_Failed"/>
                    <MediaElement x:Name="VideoRear"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" Visibility="Hidden" IsMuted="True"
                                  MediaOpened="Media_Opened"
                                  MediaEnded="Media_Ended"
                                  MediaFailed="Media_Failed"/>
                    <MediaElement x:Name="VideoRight"
                                  LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" Visibility="Hidden" IsMuted="True"
                                  MediaOpened="Media_Opened"
                                  MediaEnded="Media_Ended"
                                  MediaFailed="Media_Failed"/>
                </Grid>

            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
